# Docker Compose Environment Variables
# Copy this file to .env.docker and update with secure values for your environment
# Usage: docker-compose --env-file .env.docker up -d

# Redis
REDIS_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# PostgreSQL
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
POSTGRES_USER=prabogo
POSTGRES_DB=prabogo

# RabbitMQ
RABBITMQ_USER=prabogo
RABBITMQ_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
